# Logging (Lambda → CloudWatch). INFO | DEBUG | WARNING
LOG_LEVEL=INFO

# Optional: comma-separated browser origins for Lambda CORS tightening
# Chrome: chrome-extension://YOUR_EXTENSION_ID
# Firefox: moz-extension://YOUR_EXTENSION_UUID (from about:debugging)
OPENSCOUT_ALLOWED_ORIGINS=

# Dev toggles — true or false (default: both true)
# OPENSCOUT_ENABLE_EBAY=false
# OPENSCOUT_ENABLE_SHOPPING=false

# Required
GEMINI_API_KEY=

# Gemini latency tuning. "thinking" is the dominant request latency on 2.5 models;
# budget 0 disables it. Raise the verification budget (e.g. 256/512) if match
# quality regresses. Models can be any Gemini 2.5 id (flash, flash-lite).
# GEMINI_EXTRACTION_MODEL=gemini-2.5-flash-lite
# GEMINI_VERIFICATION_MODEL=gemini-2.5-flash
# GEMINI_EXTRACTION_THINKING_BUDGET=0
# GEMINI_VERIFICATION_THINKING_BUDGET=0
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# Optional eBay affiliate (EPN)
EBAY_AFFILIATE_CAMPID=

# SerpApi — Google Shopping multi-retailer search (https://serpapi.com/google-shopping-api)
SERP_API_KEY=
GOOGLE_SHOPPING_GL=us
GOOGLE_SHOPPING_HL=en
GOOGLE_SHOPPING_LOCATION=United States

# SHEIN KOC/affiliate link params (applied when Google Shopping result is from SHEIN)
SHEIN_AFFILIATE_KOC_ID=
SHEIN_AFFILIATE_CAMPAIGN_ID=28
SHEIN_AFFILIATE_ONELINK=
SHEIN_DOMAIN=us.shein.com

# Local dev only — Lambda uses IAM role, not these
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2
