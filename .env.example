LOG_LEVEL=INFO

OPENSCOUT_ALLOWED_ORIGINS=

# Required
GEMINI_API_KEY=


GEMINI_EXTRACTION_MODEL=gemini-2.5-flash-lite
GEMINI_VERIFICATION_MODEL=gemini-2.5-flash
GEMINI_EXTRACTION_THINKING_BUDGET=0
GEMINI_VERIFICATION_THINKING_BUDGET=0
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US


# SerpApi — Google Shopping multi-retailer search (https://serpapi.com/google-shopping-api)
SERP_API_KEY=
GOOGLE_SHOPPING_GL=us
GOOGLE_SHOPPING_HL=en
GOOGLE_SHOPPING_LOCATION=United States

# Local dev only — Lambda uses IAM role, not these
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2
