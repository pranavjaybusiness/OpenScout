GEMINI_API_KEY=

# --- eBay (Browse search) -------------------------------------------------
# Sandbox and Production use different OAuth keys AND different API hosts.
# If you only have Sandbox keys from developer.ebay.com → Keys → Sandbox:
EBAY_USE_SANDBOX=true
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Production only: set EBAY_USE_SANDBOX=false or omit it, use Production keys.
# EBAY_USE_SANDBOX=false

# OAuth Client ID + Client Secret from the same keyset (not Dev ID).
EBAY_MARKETPLACE_ID=EBAY_US
