# Logging (Lambda → CloudWatch). INFO | DEBUG | WARNING
LOG_LEVEL=INFO

# Optional: comma-separated browser origins for Lambda CORS tightening
# Chrome: chrome-extension://YOUR_EXTENSION_ID
# Firefox: moz-extension://YOUR_EXTENSION_UUID (from about:debugging)
OPENSCOUT_ALLOWED_ORIGINS=

# Required
GEMINI_API_KEY=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# Optional eBay affiliate (EPN)
EBAY_AFFILIATE_CAMPID=

# Local dev only — Lambda uses IAM role, not these
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2
