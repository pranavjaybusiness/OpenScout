{
  "manifest_version": 3,
  "name": "OpenScout",
  "version": "1.2",
  "description": "Automated product parser and price comparator.",
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.ebay.com/*",
    "*://*.walmart.com/*",
    "*://*.bestbuy.com/*",
    "*://*.nordstrom.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.ebay.com/*",
        "*://*.walmart.com/*",
        "*://*.bestbuy.com/*",
        "*://*.nordstrom.com/*"
      ],
      "js": [
        "src/detector.js",
        "src/scraper.js",
        "src/ui.js",
        "content.js"
      ],
      "run_at": "document_idle" 
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}